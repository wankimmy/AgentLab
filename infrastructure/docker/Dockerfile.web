FROM node:22-alpine AS base

WORKDIR /app

COPY apps/web/package.json ./
RUN npm install

COPY apps/web/ .

FROM base AS dev
EXPOSE 3000
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]

FROM base AS prod
RUN npm run build
ENV NODE_ENV=production
ENV HOST=0.0.0.0
ENV PORT=3000
EXPOSE 3000
CMD ["node", ".output/server/index.mjs"]
