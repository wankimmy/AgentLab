# Application
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-long-random-string
APP_DOMAIN=localhost

# Database
DATABASE_URL=postgresql://agentlab:agentlab@postgres:5432/agentlab
POSTGRES_USER=agentlab
POSTGRES_PASSWORD=agentlab
POSTGRES_DB=agentlab

# Redis
REDIS_URL=redis://redis:6379/0

# Auth (owner seeded on startup)
OWNER_EMAIL=owner@agentlab.local
OWNER_PASSWORD=changeme

# CORS
CORS_ORIGINS=http://localhost:3000

# AI Providers (Phase 3+)
AI_BASE_URL=
AI_API_KEY=
AI_DEFAULT_MODEL=

EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=

JUDGE_BASE_URL=
JUDGE_API_KEY=
JUDGE_MODEL=

MLFLOW_TRACKING_URI=

# OpenTelemetry (Phase 10)
OTEL_ENABLED=true
OTEL_SERVICE_NAME=agentlab-api
OTEL_EXPORTER_OTLP_ENDPOINT=

# Demo read-only account (optional; seeded on startup)
DEMO_EMAIL=demo@agentlab.local
DEMO_PASSWORD=change-me-demo

# Production deploy (Phase 11)
DOMAIN=agentlab.example.com
ACME_EMAIL=admin@example.com
IMAGE_TAG=latest
# GHCR images (production VPS; set by deploy workflow)
API_IMAGE=
WEB_IMAGE=
